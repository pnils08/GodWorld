{
  "description": "GodWorld: Session lifecycle + pre-tool safety checks + skill suggestions",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/skill-suggest.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/session-startup-hook.sh\"",
            "timeout": 10
          },
          {
            "type": "http",
            "url": "http://localhost:3001/api/session-events",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/pre-tool-check.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/memory-write-gate.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/tool-counter.sh\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/post-write-check.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/post-deploy-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matchers": [
          {
            "trigger": "auto"
          }
        ],
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/pre-compact-hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/post-compact-hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/stop-hook.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/session-eval.js\"",
            "timeout": 15
          },
          {
            "type": "http",
            "url": "http://localhost:3001/api/session-events",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/api/session-events",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/api/session-events",
            "timeout": 5
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/api/session-events",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
