node_modules/
package-lock.json

# Environment variables (secrets) — Phase 40.3 relocated to /root/.config/godworld/.env
# These patterns remain as belt-and-suspenders: any stray .env or credentials/ in the
# repo working dir MUST be ignored even if accidentally created.
.env
.env.*

# Service account credentials (never commit) — Phase 40.3 relocated outside repo
credentials/
*.service-account.json
*service-account.json

# SQLite database (local persistence, not tracked)
godworld/godworld.db
godworld/*.db

# Exported cycle artifacts (generated, large)
exports/*.json

# Generated media output (root-level only, not docs/media/)
/media/

# MCP server config (contains API keys)
.mcp.json

# Generated desk packets and cycle output
output/

# Logs (generated runtime output)
logs/

# Backups (local archive copies, uploaded to Drive)
backups/

# Supermemory plugin config (may contain API keys)
.claude/.supermemory-claude/
creds.json
.venv/

# Podcast audio output (uploaded to Drive, not needed in repo)
data/audio/
.playwright-mcp/

# Graphify output (generated knowledge graph artifacts, regenerated on demand)
graphify-out/
**/graphify-out/
output/audit-reports/
output/audit-state.json
