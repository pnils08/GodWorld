{
  "description": "GodWorld: Session lifecycle + pre-tool safety checks + skill suggestions",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/skill-suggest.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/session-startup-hook.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "EVENT_TYPE=session_start bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/session-event-post.sh\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/pre-tool-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/post-write-check.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matchers": [
          {
            "trigger": "auto"
          }
        ],
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/pre-compact-hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/post-compact-hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/stop-hook.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "EVENT_TYPE=session_stop bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/session-event-post.sh\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
