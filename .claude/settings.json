{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__plugin_claude-mem_mcp-search__search",
      "mcp__plugin_claude-mem_mcp-search__get_observations",
      "mcp__plugin_claude-mem_mcp-search__observation_search",
      "mcp__plugin_claude-mem_mcp-search__observation_context",
      "mcp__plugin_claude-mem_mcp-search__timeline",
      "mcp__plugin_claude-mem_mcp-search__smart_outline",
      "mcp__plugin_claude-mem_mcp-search__smart_search",
      "mcp__plugin_claude-mem_mcp-search__smart_unfold",
      "mcp__godworld__lookup_initiative",
      "mcp__godworld__lookup_citizen",
      "mcp__godworld__lookup_business",
      "mcp__godworld__lookup_cultural",
      "mcp__godworld__lookup_faith_org",
      "mcp__godworld__get_council_member",
      "mcp__godworld__get_domain_ratings",
      "mcp__godworld__get_neighborhood",
      "mcp__godworld__get_neighborhood_state",
      "mcp__godworld__get_roster",
      "mcp__godworld__search_articles",
      "mcp__godworld__search_canon",
      "mcp__godworld__search_everything",
      "mcp__godworld__search_world",
      "mcp__claude_ai_Google_Drive__get_file_metadata",
      "mcp__claude_ai_Google_Drive__get_file_permissions",
      "mcp__claude_ai_Google_Drive__list_recent_files",
      "mcp__claude_ai_Google_Drive__read_file_content",
      "mcp__claude_ai_Google_Drive__download_file_content",
      "mcp__claude_ai_Google_Drive__search_files",
      "mcp__claude_ai_Google_Drive__create_file",
      "mcp__claude_ai_Google_Drive__copy_file",
      "Read(/root/GodWorld/**)",
      "Edit(/root/GodWorld/**)",
      "Write(/root/GodWorld/**)",
      "Write(/root/GodWorld/output/reporters/**)",
      "Edit(/root/GodWorld/output/reporters/**)",
      "Write(/root/GodWorld/output/quick-takes/**)",
      "Edit(/root/GodWorld/output/quick-takes/**)",
      "Write(/root/GodWorld/output/letters/**)",
      "Edit(/root/GodWorld/output/letters/**)",
      "Write(/root/GodWorld/output/desks/**)",
      "Edit(/root/GodWorld/output/desks/**)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(node scripts/buildDeskPackets*)",
      "Bash(node scripts/buildWorldSummary*)",
      "Bash(node scripts/buildInitiativePackets*)",
      "Bash(node scripts/queryLedger*)",
      "Bash(node scripts/queryFamily*)",
      "Bash(node scripts/magsPageRecall*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(stat:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(sqlite3:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf /root*)",
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(**/credentials*)",
      "Read(**/secrets*)",
      "Read(**/*_key*)",
      "Read(**/*token*)",
      "Read(/root/GodWorld/.env*)",
      "Read(/root/GodWorld/credentials/**)",
      "Read(/root/.config/godworld/**)",
      "Read(**/credentials/service-account.json)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.kube/*)",
      "Edit(.env*)",
      "Edit(**/.env*)",
      "Write(.env*)",
      "Write(**/.env*)"
    ],
    "ask": [
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(clasp *)",
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(node scripts/ingestEdition*)",
      "Bash(node scripts/ingestEditionWiki*)",
      "Bash(node scripts/buildCitizenCards*)",
      "Bash(npx supermemory add*)",
      "Bash(npx supermemory ingest*)",
      "Bash(curl *api.supermemory.ai*)",
      "Edit(.claude/terminals/**)",
      "Write(.claude/terminals/**)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Edit(.claude/rules/**)",
      "Write(.claude/rules/**)",
      "Edit(.claude/hooks/**)",
      "Write(.claude/hooks/**)",
      "Edit(.claude/agents/**)",
      "Write(.claude/agents/**)",
      "Edit(SESSION_CONTEXT.md)",
      "Write(SESSION_CONTEXT.md)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/GodWorld/scripts/rolloutPointerGuard.js",
            "if": "Edit(docs/engine/ROLLOUT_PLAN.md)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node /root/GodWorld/scripts/rolloutPointerGuard.js",
            "if": "Write(docs/engine/ROLLOUT_PLAN.md)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node /root/GodWorld/scripts/rolloutPointerGuard.js",
            "if": "Edit(docs/plans/**)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node /root/GodWorld/scripts/rolloutPointerGuard.js",
            "if": "Write(docs/plans/**)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /root/GodWorld/.claude/hooks/session-context-ownership-guard.sh",
            "if": "Edit(SESSION_CONTEXT.md)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /root/GodWorld/.claude/hooks/session-context-ownership-guard.sh",
            "if": "Write(SESSION_CONTEXT.md)",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/GodWorld/.claude/hooks/session-startup-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /root/GodWorld/scripts/session-eval.js",
            "timeout": 15,
            "async": true
          },
          {
            "type": "command",
            "command": "bash /root/GodWorld/scripts/session-end-audit.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "autoMode": {
    "allow": [
      "Read, Edit, Write, Glob, Grep are safe for all project files",
      "Bash commands for node scripts, git status/log/diff/add/commit, ls, wc, mkdir, chmod, npm, npx",
      "WebFetch and WebSearch for research",
      "All MCP tool calls for discord, supermemory, playwright, context7"
    ],
    "soft_deny": [
      "git push — confirm branch and commit count before pushing",
      "clasp push — always show pre-flight (changed files, branch, uncommitted changes)",
      "rm commands — verify target path before deleting",
      "curl/wget — confirm URL before fetching",
      "git merge/rebase/checkout/switch — confirm current state first",
      "Any command that writes to Simulation_Ledger or production Google Sheets"
    ],
    "environment": [
      "This is GodWorld — a city simulation engine with a newsroom pipeline",
      "675 citizens in Simulation_Ledger — destructive sheet operations risk data loss",
      "Service account credentials in credentials/ — never read or expose",
      ".env contains API keys — never read or expose",
      "bay-tribune Supermemory container is agent-facing canon — never write system internals to it",
      "Agent files (.claude/agents/) must never contain simulation/engine/builder references"
    ]
  }
}
